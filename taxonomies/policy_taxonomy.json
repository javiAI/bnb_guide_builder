        {
          "id": "pol.smoking",
          "label": "Fumar / vapear",
          "description": "Permisos y restricciones sobre tabaco, vapeo y cigarrillos electrónicos.",
          "type": "enum",
          "required": true,
          "recommended": true,
          "default": "not_allowed",
          "options": [
            {
              "id": "not_allowed",
              "label": "No permitido",
              "description": "Prohibido en toda la propiedad.",
              "recommended": true
            },
            {
              "id": "outdoors_only",
              "label": "Solo en exterior",
              "description": "Permitido únicamente fuera del alojamiento."
            },
            {
              "id": "designated_area",
              "label": "Zona designada",
              "description": "Permitido solo en zonas marcadas."
            },
            {
              "id": "no_restriction",
              "label": "Sin restricción",
              "description": "Sin restricciones específicas."
            }
          ],
          "dependency_hints": [],
          "journeyStage": "arrival",
          "journeyTags": [
            "essential"
