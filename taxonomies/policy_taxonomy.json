        {
          "id": "pol.events",
          "label": "Eventos y reuniones",
          "description": "Restricciones sobre fiestas, reuniones y celebraciones.",
          "type": "enum",
          "required": true,
          "recommended": true,
          "default": "not_allowed",
          "options": [
            {
              "id": "not_allowed",
              "label": "No permitidos",
              "description": "No se permiten fiestas ni reuniones.",
              "recommended": true
            },
            {
              "id": "small_gatherings",
              "label": "Pequeñas reuniones",
              "description": "Se permiten reuniones reducidas hasta un máximo de personas."
            },
            {
              "id": "with_approval",
              "label": "Con aprobación previa",
              "description": "Requiere autorización explícita del anfitrión."
            }
          ],
          "dependency_hints": [
            "Si se permite algún nivel, mostrar límites y condiciones."
          ],
          "source": [],
          "platform_supported": false
        },
        {
          "id": "pol.pets",
          "label": "Mascotas",
          "description": "Permisos, límites, cargos y restricciones relativos a mascotas.",
          "type": "object_optional",
          "required": false,
          "recommended": true,
          "default": {
            "allowed": false
          },
          "fields": [
            {
              "id": "allowed",
              "label": "¿Se permiten mascotas?",
              "description": "Activa reglas específicas de mascotas.",
              "type": "boolean",
              "default": false
            },
            {
              "id": "types",
              "label": "Tipos permitidos",
              "description": "Qué tipos de mascotas se admiten.",
              "type": "multi_select",
              "shown_if": {
                "field": "allowed",
                "equals": true
              },
              "options": [
                {
                  "id": "dogs",
                  "label": "Perros",
                  "description": "Se admiten perros."
                },
                {
                  "id": "cats",
                  "label": "Gatos",
                  "description": "Se admiten gatos."
                },
                {
                  "id": "other",
                  "label": "Otros",
                  "description": "Otros animales (especificar en notas)."
                }
              ]
            },
            {
              "id": "size_restriction",
              "label": "Restricción de tamaño",
              "description": "Límite de peso para mascotas admitidas.",
              "type": "enum",
              "shown_if": {
                "field": "allowed",
                "equals": true
              },
              "options": [
                {
                  "id": "none",
                  "label": "Sin restricción",
                  "description": "Se admiten mascotas de cualquier tamaño."
                },
                {
                  "id": "small_only",
                  "label": "Solo pequeños (< 10 kg)",
                  "description": "Solo mascotas de hasta 10 kg."
                },
                {
                  "id": "medium_max",
                  "label": "Medianos (< 25 kg)",
                  "description": "Solo mascotas de hasta 25 kg."
                },
                {
                  "id": "custom_weight",
                  "label": "Peso máximo personalizado",
                  "description": "Establece un límite de peso específico."
                }
              ]
            },
            {
              "id": "max",
              "label": "Número máximo",
              "description": "Número máximo de mascotas permitido.",
              "type": "number",
              "min": 1,
              "max": 10,
              "shown_if": {
                "field": "allowed",
                "equals": true
              }
            },
            {
              "id": "fee_mode",
              "label": "Modo de cargo",
              "description": "Forma de cobro del suplemento de mascotas.",
              "type": "enum",
              "shown_if": {
                "field": "allowed",
                "equals": true
              },
              "options": [
                {
                  "id": "none",
                  "label": "Sin cargo",
                  "description": "No se cobra suplemento por mascota."
                },
                {
                  "id": "per_booking",
                  "label": "Por reserva",
                  "description": "Un único cargo por toda la reserva."
                },
                {
                  "id": "per_night",
                  "label": "Por noche",
                  "description": "Cargo por noche."
                },
                {
                  "id": "per_pet",
                  "label": "Por mascota",
                  "description": "Cargo fijo por cada mascota."
                },
                {
                  "id": "per_pet_per_night",
                  "label": "Por mascota y noche",
                  "description": "Cargo recurrente por cada mascota y noche."
                }
              ]
            },
            {
              "id": "fee_amount",
              "label": "Importe del suplemento",
              "description": "Cantidad económica del cargo, en euros.",
              "type": "money",
              "currency": "EUR",
              "shown_if": {
                "field": "allowed",
                "equals": true
              }
            },
            {
              "id": "restrictions",
              "label": "Restricciones adicionales",
              "description": "Límites por zonas, limpieza u otros criterios.",
              "type": "multi_select_optional",
              "shown_if": {
                "field": "allowed",
                "equals": true
              },
              "options": [
                {
                  "id": "no_bedrooms",
                  "label": "No en dormitorios",
                  "description": "Se restringe el acceso a los dormitorios."
                },
                {
                  "id": "no_sofas",
                  "label": "No en sofás ni camas",
                  "description": "No se permite subir a sofás o camas."
                },
                {
                  "id": "extra_cleaning",
                  "label": "Limpieza extra obligatoria",
                  "description": "Se exige protocolo extra de limpieza o suplemento adicional."
                },
                {
                  "id": "must_be_supervised",
                  "label": "Supervisadas en todo momento",
                  "description": "La mascota no debe quedarse sola en la propiedad."
                }
              ]
            },
            {
              "id": "service_animals",
              "label": "Animales de servicio",
              "description": "Tratamiento específico para animales de servicio.",
              "type": "enum",
              "default": "allowed_free",
              "options": [
                {
                  "id": "allowed_free",
                  "label": "Siempre permitidos sin suplemento",
                  "description": "Configuración recomendada para evitar ambigüedad.",
                  "recommended": true
                }
              ]
            }
          ],
          "dependency_hints": [
            "Si allowed=true, activar plantillas y operación relacionadas con mascotas."
          ],
