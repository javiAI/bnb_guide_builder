datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

// Visibility level for any property-scoped content. Ordered from broadest
// audience (guest) to most restricted (sensitive). Consumers compare via
// src/lib/visibility.ts VISIBILITY_ORDER.
enum VisibilityLevel {
  guest
  ai
  internal
  sensitive
}

// ──────────────────────────────────────────────
// Core context
// ──────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members        WorkspaceMembership[]
  properties     Property[]
  wizardSessions WizardSession[]

  @@map("workspaces")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships  WorkspaceMembership[]
  mediaAssets  MediaAsset[]

  @@map("users")
}

model WorkspaceMembership {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  role        String   @default("owner")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@map("workspace_memberships")
}

model Property {
  id               String   @id @default(cuid())
  workspaceId      String   @map("workspace_id")
  propertyNickname String   @map("property_nickname")
  propertyType     String?  @map("property_type")
  roomType         String?  @map("room_type")
  layoutKey        String?  @map("layout_key")
  propertyEnvironment String? @map("property_environment")
  country          String?
  city             String?
  region           String?
  postalCode       String?  @map("postal_code")
  streetAddress    String?  @map("street_address")
  addressExtra     String?  @map("address_extra")
  addressLevel     String?  @map("address_level")
  timezone         String?
  latitude         Float?
  longitude        Float?
  maxGuests        Int?     @map("max_guests")
  maxAdults        Int      @default(2) @map("max_adults")
  maxChildren      Int      @default(0) @map("max_children")
  childrenAgeLimit Int      @default(14) @map("children_age_limit")
  bedroomsCount    Int?     @map("bedrooms_count")
  bedsCount        Int?     @map("beds_count")
  bathroomsCount   Int?     @map("bathrooms_count")
  checkInStart     String?  @map("check_in_start")
  checkInEnd       String?  @map("check_in_end")
  checkOutTime     String?  @map("check_out_time")
  primaryAccessMethod String? @map("primary_access_method")
  accessMethodsJson   Json?    @map("access_methods_json")
  policiesJson     Json?    @map("policies_json")
  customPropertyTypeLabel String? @map("custom_property_type_label")
  customPropertyTypeDesc  String? @map("custom_property_type_desc")
  customRoomTypeLabel     String? @map("custom_room_type_label")
  customRoomTypeDesc      String? @map("custom_room_type_desc")
  customAccessMethodLabel String? @map("custom_access_method_label")
  customAccessMethodDesc  String? @map("custom_access_method_desc")
  infantsAllowed          Boolean @default(false) @map("infants_allowed")
  isAutonomousCheckin     Boolean @default(false) @map("is_autonomous_checkin")
  hasBuildingAccess       Boolean @default(false) @map("has_building_access")
  hasPrivateEntrance      Boolean @default(false) @map("has_private_entrance")
  infrastructureJson      Json?   @map("infrastructure_json")
  publicSlug       String?  @unique @map("public_slug")
  brandLogoUrl     String?  @map("brand_logo_url")
  brandPaletteKey  String?  @map("brand_palette_key")
  defaultLocale    String   @default("es") @map("default_locale")
  status           String   @default("draft")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace             Workspace               @relation(fields: [workspaceId], references: [id])
  wizardSessions        WizardSession[]
  spaces                Space[]
  systems               PropertySystem[]
  amenityInstances      PropertyAmenityInstance[]
  troubleshootingPlaybooks TroubleshootingPlaybook[]
  incidents             Incident[]
  localPlaces           LocalPlace[]
  opsChecklistItems     OpsChecklistItem[]
  stockItems            StockItem[]
  maintenanceTasks      MaintenanceTask[]
  mediaAssets           MediaAsset[]
  knowledgeSources      KnowledgeSource[]
  knowledgeItems        KnowledgeItem[]
  guideVersions         GuideVersion[]
  messageTemplates      MessageTemplate[]
  messageAutomations    MessageAutomation[]
  messageDrafts         MessageDraft[]
  assistantConversations AssistantConversation[]
  secretReferences      SecretReference[]
  auditLogs             AuditLog[]
  contacts              Contact[]
  derived               PropertyDerived?

  @@unique([workspaceId, propertyNickname])
  @@index([workspaceId])
  @@index([status])
  @@map("properties")
}

// ──────────────────────────────────────────────
// Derived state cache (Phase 4A)
// ──────────────────────────────────────────────

model PropertyDerived {
  propertyId   String   @id @map("property_id")
  derivedJson  Json     @map("derived_json")
  recomputedAt DateTime @default(now()) @map("recomputed_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_derived")
}

// ──────────────────────────────────────────────
// Capture and continuity
// ──────────────────────────────────────────────

model WizardSession {
  id               String    @id @default(cuid())
  workspaceId      String    @map("workspace_id")
  propertyId       String?   @map("property_id")
  propertyNickname String?   @map("property_nickname")
  stateJson        Json?     @map("state_json")
  status           String    @default("in_progress")
  currentStep      Int       @default(1) @map("current_step")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  workspace Workspace       @relation(fields: [workspaceId], references: [id])
  property  Property?       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  responses WizardResponse[]

  @@index([workspaceId])
  @@index([propertyId])
  @@map("wizard_sessions")
}

model WizardResponse {
  id              String   @id @default(cuid())
  wizardSessionId String   @map("wizard_session_id")
  stepNumber      Int      @map("step_number")
  fieldKey        String   @map("field_key")
  valueJson       Json     @map("value_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  wizardSession WizardSession @relation(fields: [wizardSessionId], references: [id], onDelete: Cascade)

  @@index([wizardSessionId])
  @@map("wizard_responses")
}

// ──────────────────────────────────────────────
// Contacts
// ──────────────────────────────────────────────

model Contact {
  id                     String   @id @default(cuid())
  propertyId             String   @map("property_id")
  roleKey                String   @map("role_key")
  entityType             String   @default("person") @map("entity_type")
  displayName            String   @map("display_name")
  contactPersonName      String?  @map("contact_person_name")
  phone                  String?
  phoneSecondary         String?  @map("phone_secondary")
  email                  String?
  whatsapp               String?
  address                String?
  availabilitySchedule   String?  @map("availability_schedule")
  emergencyAvailable     Boolean  @default(false) @map("emergency_available")
  hasPropertyAccess      Boolean  @default(false) @map("has_property_access")
  internalNotes          String?  @map("internal_notes")
  guestVisibleNotes      String?  @map("guest_visible_notes")
  visibility             VisibilityLevel @default(internal)
  isPrimary              Boolean  @default(false) @map("is_primary")
  sortOrder              Int      @default(0) @map("sort_order")
  metadataJson           Json?    @map("metadata_json")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([propertyId, roleKey])
  @@map("contacts")
}

// ──────────────────────────────────────────────
// Canonical property entities
// ──────────────────────────────────────────────

model Space {
  id            String   @id @default(cuid())
  propertyId    String   @map("property_id")
  spaceType     String   @map("space_type")
  name          String
  sortOrder     Int      @default(0) @map("sort_order")
  guestNotes    String?  @map("guest_notes")
  aiNotes       String?  @map("ai_notes")
  internalNotes String?  @map("internal_notes")
  visibility    VisibilityLevel @default(guest)
  status        String   @default("active")
  createdBy     String   @default("user") @map("created_by")
  wizardSeedKey String?  @map("wizard_seed_key")
  featuresJson  Json?    @map("features_json")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  property         Property                  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  beds             BedConfiguration[]
  systemCoverages  PropertySystemCoverage[]
  amenityPlacements PropertyAmenityPlacement[]
  troubleshootingPlaybooks TroubleshootingPlaybook[]

  @@unique([propertyId, wizardSeedKey])
  @@index([propertyId])
  @@index([propertyId, visibility])
  @@index([propertyId, status])
  @@map("spaces")
}

model BedConfiguration {
  id            String   @id @default(cuid())
  spaceId       String   @map("space_id")
  bedType       String   @map("bed_type")
  quantity      Int      @default(1)
  configJson    Json?    @map("config_json")
  wizardSeedKey String?  @map("wizard_seed_key")
  createdAt     DateTime @default(now()) @map("created_at")

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, wizardSeedKey])
  @@index([spaceId])
  @@map("bed_configurations")
}

model PropertySystem {
  id            String   @id @default(cuid())
  propertyId    String   @map("property_id")
  systemKey     String   @map("system_key")
  detailsJson   Json?    @map("details_json")
  opsJson       Json?    @map("ops_json")
  internalNotes String?  @map("internal_notes")
  visibility    VisibilityLevel @default(guest)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  property  Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  coverages PropertySystemCoverage[]

  @@unique([propertyId, systemKey])
  @@index([propertyId])
  @@map("property_systems")
}

model PropertySystemCoverage {
  id         String   @id @default(cuid())
  systemId   String   @map("system_id")
  spaceId    String   @map("space_id")
  mode       String   @default("inherited")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  system PropertySystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
  space  Space          @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([systemId, spaceId])
  @@index([systemId])
  @@index([spaceId])
  @@map("property_system_coverages")
}

model PropertyAmenityInstance {
  id                   String   @id @default(cuid())
  propertyId           String   @map("property_id")
  amenityKey           String   @map("amenity_key")
  instanceKey          String   @default("default") @map("instance_key")
  subtypeKey           String?  @map("subtype_key")
  detailsJson          Json?    @map("details_json")
  guestInstructions    String?  @map("guest_instructions")
  aiInstructions       String?  @map("ai_instructions")
  internalNotes        String?  @map("internal_notes")
  troubleshootingNotes String?  @map("troubleshooting_notes")
  runbookJson          Json?    @map("runbook_json")
  visibility           VisibilityLevel @default(guest)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  property   Property                   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  placements PropertyAmenityPlacement[]

  @@unique([propertyId, amenityKey, instanceKey])
  @@index([propertyId])
  @@index([propertyId, amenityKey])
  @@map("property_amenity_instances")
}

model PropertyAmenityPlacement {
  id         String   @id @default(cuid())
  amenityId  String   @map("amenity_id")
  spaceId    String   @map("space_id")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  amenity PropertyAmenityInstance @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  space   Space                   @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([amenityId, spaceId])
  @@index([amenityId])
  @@index([spaceId])
  @@map("property_amenity_placements")
}

model TroubleshootingPlaybook {
  id              String   @id @default(cuid())
  propertyId      String   @map("property_id")
  playbookKey     String   @map("playbook_key")
  title           String
  severity        String   @default("medium")
  symptomsMd      String?  @map("symptoms_md")
  guestStepsMd    String?  @map("guest_steps_md")
  internalStepsMd String?  @map("internal_steps_md")
  escalationRule  String?  @map("escalation_rule")
  visibility      VisibilityLevel @default(guest)
  language        String   @default("es")
  systemKey       String?  @map("system_key")
  amenityKey      String?  @map("amenity_key")
  spaceId         String?  @map("space_id")
  accessMethodKey String?  @map("access_method_key")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  property  Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  space     Space?     @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  incidents Incident[]

  @@index([propertyId])
  @@index([propertyId, playbookKey])
  @@index([propertyId, systemKey])
  @@index([propertyId, amenityKey])
  @@index([spaceId])
  @@index([propertyId, accessMethodKey])
  @@map("troubleshooting_playbooks")
}

model Incident {
  id          String    @id @default(cuid())
  propertyId  String    @map("property_id")
  title       String
  severity    String    @default("medium")
  status      String    @default("open") // open | in_progress | resolved | cancelled
  targetType  String    @map("target_type") // system | amenity | space | access | property
  targetId    String?   @map("target_id")
  playbookId  String?   @map("playbook_id")
  notes       String?
  visibility  VisibilityLevel @default(internal)
  occurredAt  DateTime  @map("occurred_at")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  property Property                 @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  playbook TroubleshootingPlaybook? @relation(fields: [playbookId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([propertyId, status])
  @@index([propertyId, targetType, targetId])
  @@index([playbookId])
  @@map("incidents")
}

model LocalPlace {
  id               String    @id @default(cuid())
  propertyId       String    @map("property_id")
  categoryKey      String    @map("category_key")
  name             String
  shortNote        String?   @map("short_note")
  guestDescription String?   @map("guest_description")
  aiNotes          String?   @map("ai_notes")
  distanceMeters   Int?      @map("distance_meters")
  hoursText        String?   @map("hours_text")
  linkUrl          String?   @map("link_url")
  bestFor          String?   @map("best_for")
  seasonalNotes    String?   @map("seasonal_notes")
  verifiedAt       DateTime? @map("verified_at")
  visibility       VisibilityLevel @default(guest)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([propertyId, categoryKey])
  @@map("local_places")
}

model OpsChecklistItem {
  id               String   @id @default(cuid())
  propertyId       String   @map("property_id")
  scopeKey         String   @map("scope_key")
  title            String
  detailsMd        String?  @map("details_md")
  estimatedMinutes Int?     @map("estimated_minutes")
  required         Boolean  @default(false)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("ops_checklist_items")
}

model StockItem {
  id               String   @id @default(cuid())
  propertyId       String   @map("property_id")
  categoryKey      String   @map("category_key")
  name             String
  restockThreshold Int?     @map("restock_threshold")
  locationNote     String?  @map("location_note")
  unitLabel        String?  @map("unit_label")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("stock_items")
}

model MaintenanceTask {
  id         String    @id @default(cuid())
  propertyId String    @map("property_id")
  taskType   String    @map("task_type")
  title      String
  cadenceKey String?   @map("cadence_key")
  nextDueAt  DateTime? @map("next_due_at")
  ownerNote  String?   @map("owner_note")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([nextDueAt])
  @@map("maintenance_tasks")
}

// ──────────────────────────────────────────────
// Media
// ──────────────────────────────────────────────

model MediaAsset {
  id               String   @id @default(cuid())
  propertyId       String   @map("property_id")
  assetRoleKey     String   @map("asset_role_key")
  mediaType        String   @map("media_type")
  storageKey       String   @map("storage_key")
  mimeType         String   @map("mime_type")
  language         String   @default("es")
  caption          String?
  visibility       VisibilityLevel @default(guest)
  sizeBytes        Int?     @map("size_bytes")
  blurhash         String?
  contentHash      String?  @map("content_hash")
  status           String   @default("pending")
  uploadedByUserId String?  @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  property     Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  uploadedBy   User?             @relation(fields: [uploadedByUserId], references: [id])
  assignments  MediaAssignment[]

  @@index([propertyId])
  @@index([propertyId, visibility, status])
  @@map("media_assets")
}

model MediaAssignment {
  id           String   @id @default(cuid())
  mediaAssetId String   @map("media_asset_id")
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  sortOrder    Int      @default(0) @map("sort_order")
  usageKey     String?  @map("usage_key")
  createdAt    DateTime @default(now()) @map("created_at")

  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([mediaAssetId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("media_assignments")
}

// ──────────────────────────────────────────────
// Knowledge and guide
// ──────────────────────────────────────────────

model KnowledgeSource {
  id            String   @id @default(cuid())
  propertyId    String   @map("property_id")
  sourceType    String   @map("source_type")
  sourceRef     String?  @map("source_ref")
  lastSyncedAt  DateTime? @map("last_synced_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  property  Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  items     KnowledgeItem[]
  citations KnowledgeCitation[]

  @@index([propertyId])
  @@map("knowledge_sources")
}

model KnowledgeItem {
  id               String          @id @default(cuid())
  propertyId       String          @map("property_id")
  sourceId         String?         @map("source_id")
  topic            String
  bodyMd           String          @map("body_md")
  locale           String          @default("es")
  visibility       VisibilityLevel @default(guest)
  confidenceScore  Float           @default(0.5) @map("confidence_score")
  isAutoExtracted  Boolean         @default(false) @map("is_auto_extracted")
  journeyStage     String?         @map("journey_stage")
  lastVerifiedAt   DateTime?       @map("last_verified_at")
  chunkType        String          @default("fact") @map("chunk_type")
  entityType       String          @default("property") @map("entity_type")
  entityId         String?         @map("entity_id")
  canonicalQuestion String?        @map("canonical_question")
  contextPrefix    String          @default("") @map("context_prefix")
  bm25Text         String          @default("") @map("bm25_text")
  tokens           Int             @default(0)
  sourceFields     String[]        @default([]) @map("source_fields")
  tags             String[]        @default([])
  contentHash      String?         @map("content_hash")
  validFrom        DateTime?       @map("valid_from")
  validTo          DateTime?       @map("valid_to")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  property  Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  source    KnowledgeSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  citations KnowledgeCitation[]

  @@index([propertyId])
  @@index([propertyId, locale, visibility])
  @@index([propertyId, locale, journeyStage])
  @@index([propertyId, chunkType])
  @@index([propertyId, entityType, entityId])
  @@index([propertyId, visibility])
  @@map("knowledge_items")
}

model KnowledgeCitation {
  id              String   @id @default(cuid())
  knowledgeItemId String   @map("knowledge_item_id")
  sourceId        String   @map("source_id")
  quoteOrNote     String?  @map("quote_or_note")
  relevanceScore  Float?   @map("relevance_score")
  createdAt       DateTime @default(now()) @map("created_at")

  knowledgeItem KnowledgeItem   @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)
  source        KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([knowledgeItemId])
  @@map("knowledge_citations")
}

model Intent {
  id          String   @id @default(cuid())
  intentKey   String   @unique @map("intent_key")
  label       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("intents")
}

model GuideVersion {
  id                String    @id @default(cuid())
  propertyId        String    @map("property_id")
  version           Int       @default(1)
  status            String    @default("draft")
  treeJson          Json?     @map("tree_json")
  treeSchemaVersion Int       @default(1) @map("tree_schema_version")
  publishedAt       DateTime? @map("published_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, version])
  @@index([propertyId, status])
  @@map("guide_versions")
}

// ──────────────────────────────────────────────
// Messaging
// ──────────────────────────────────────────────

model MessageTemplate {
  id            String   @id @default(cuid())
  propertyId    String   @map("property_id")
  touchpointKey String   @map("touchpoint_key")
  channelKey    String?  @map("channel_key")
  subjectLine   String?  @map("subject_line")
  bodyMd        String   @map("body_md")
  variablesJson Json?    @map("variables_json")
  language      String   @default("es")
  status        String   @default("draft")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  property    Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  automations MessageAutomation[]

  @@index([propertyId])
  @@index([propertyId, touchpointKey])
  @@map("message_templates")
}

model MessageAutomation {
  id                String   @id @default(cuid())
  propertyId        String   @map("property_id")
  touchpointKey     String   @map("touchpoint_key")
  templateId        String   @map("template_id")
  channelKey        String   @map("channel_key")
  active            Boolean  @default(false)
  triggerType       String   @map("trigger_type")
  sendOffsetMinutes Int      @map("send_offset_minutes")
  timezoneSource    String   @default("property_timezone") @map("timezone_source")
  conditionsJson    Json?    @map("conditions_json")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  property Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  template MessageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([propertyId, touchpointKey])
  @@map("message_automations")
}

model MessageDraft {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  bodyMd     String   @map("body_md")
  channelKey String?  @map("channel_key")
  status     String   @default("draft")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("message_drafts")
}

// ──────────────────────────────────────────────
// Assistant
// ──────────────────────────────────────────────

model AssistantConversation {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  actorType  String   @map("actor_type")
  audience   String   @default("public")
  language   String   @default("es")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  property Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  messages AssistantMessage[]

  @@index([propertyId])
  @@map("assistant_conversations")
}

model AssistantMessage {
  id              String   @id @default(cuid())
  conversationId  String   @map("conversation_id")
  role            String
  body            String
  citationsJson   Json?    @map("citations_json")
  confidenceScore Float?   @map("confidence_score")
  escalated       Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  conversation AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("assistant_messages")
}

// ──────────────────────────────────────────────
// Security and audit
// ──────────────────────────────────────────────

model SecretReference {
  id          String   @id @default(cuid())
  propertyId  String   @map("property_id")
  secretType  String   @map("secret_type")
  vaultKey    String   @map("vault_key")
  label       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("secret_references")
}

model AuditLog {
  id         String   @id @default(cuid())
  propertyId String   @map("property_id")
  actor      String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  diffJson   Json?    @map("diff_json")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([propertyId, entityType])
  @@index([createdAt])
  @@map("audit_logs")
}
