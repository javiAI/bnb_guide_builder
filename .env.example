DATABASE_URL="postgresql://javierabrilibanez@localhost:5432/guide_builder?schema=public"
MAPTILER_API_KEY=your_key_here

# Cloudflare R2 (S3-compatible storage for media uploads)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=guide-builder-media

# Assistant pipeline (Rama 11C)
# In dev/test each of these may be empty — the pipeline degrades to a
# deterministic mock (embeddings) / identity reranker / synthesis stub.
# In production (NODE_ENV=production) the pipeline fails fast if any is
# missing.
VOYAGE_API_KEY=
COHERE_API_KEY=
ANTHROPIC_API_KEY=
# Model used by the synthesizer LLM. Intent resolver is pinned to
# claude-haiku-4-5-20251001 and not configurable.
ASSISTANT_LLM_MODEL=claude-sonnet-4-6

# Messaging automations scheduler (Rama 12B)
# Secret shared with Vercel Cron. The POST /api/cron/messaging endpoint
# rejects any request without `Authorization: Bearer <secret>`.
CRON_SECRET=

# Local POIs — typeahead provider (Rama 13A)
# One of `maptiler` | `mock`. Default `maptiler` when unset. `mock` serves a
# deterministic seed list without network calls (useful in dev/test). In
# NODE_ENV=production the factory fails fast if `maptiler` is selected
# without `MAPTILER_API_KEY` — silent mock in prod is never allowed.
LOCAL_POI_PROVIDER=maptiler

# Local events sync (Rama 13B)
# Keys for the three sources aggregated by POST /api/cron/local-events
# (scheduled daily at 04:00 UTC). Missing keys are non-fatal: each provider
# degrades to a `config_error` envelope and the aggregator continues with
# the remaining sources. A tick with all three keys missing succeeds with
# zero events persisted and three config_error entries in the report.
PREDICTHQ_API_KEY=
FIRECRAWL_API_KEY=
TICKETMASTER_API_KEY=

# Public guide capabilities (Rama 15C)
# Single HMAC-SHA256 key that signs every public-guide capability cookie
# (gc-<capability>-<slug>). Cross-capability and cross-slug isolation are
# enforced inside the signed envelope, not by per-capability secrets — one
# rotation invalidates all outstanding capability cookies in one move. The
# secret never reaches the client; only the derived MAC does. Replaces
# GUEST_INCIDENT_COOKIE_SECRET (deleted in 15C cutover — old cookies under
# the previous secret silently fail verify, guests re-report to regain
# read authority). Required (≥16 chars) in NODE_ENV=production; dev/test
# falls back to a deterministic placeholder.
PUBLIC_CAPABILITY_SECRET=

# Optional transactional email provider used by the host-notification service
# when a guest files an incident. Leave unset in dev/test: the notification
# service degrades to a no-op stub that logs the outbound message shape. In
# NODE_ENV=production an unset provider is allowed — notifications silently
# no-op (never block a guest report because email plumbing is missing).
EMAIL_PROVIDER=
EMAIL_FROM_ADDRESS=

# Operator authentication — Google OAuth (Rama 15A)
# Google OAuth 2.0 credentials from Google Cloud Console.
# Generate HMAC_KEY: openssl rand -hex 32 (used for HMAC-SHA256 session signing)
# In NODE_ENV=production all three OAuth vars must be set or the app fails to boot.
# In dev/test they can be set to placeholder values.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
HMAC_KEY=
