DATABASE_URL="postgresql://javierabrilibanez@localhost:5432/guide_builder?schema=public"
MAPTILER_API_KEY=your_key_here

# Cloudflare R2 (S3-compatible storage for media uploads)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=guide-builder-media

# Assistant pipeline (Rama 11C)
# In dev/test each of these may be empty — the pipeline degrades to a
# deterministic mock (embeddings) / identity reranker / synthesis stub.
# In production (NODE_ENV=production) the pipeline fails fast if any is
# missing.
VOYAGE_API_KEY=
COHERE_API_KEY=
ANTHROPIC_API_KEY=
# Model used by the synthesizer LLM. Intent resolver is pinned to
# claude-haiku-4-5-20251001 and not configurable.
ASSISTANT_LLM_MODEL=claude-sonnet-4-6
